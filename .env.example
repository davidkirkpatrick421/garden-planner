# ─────────────────────────────────────────────────────────────────────────────
# Garden Sun — environment variables
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored and must NEVER be committed.
#
# ⚠️  SECURITY: every variable prefixed with VITE_ is inlined into the client
# bundle and shipped to every browser. It is PUBLIC. Never put a secret behind
# a VITE_ prefix.
# ─────────────────────────────────────────────────────────────────────────────

# Mapbox — PUBLIC token only (must start with `pk.`, never `sk.`).
# Lock it down in the Mapbox dashboard with URL restrictions
# (http://localhost:5173/* for dev, your Vercel domain for prod) so a scraped
# token can't be reused elsewhere.
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# Supabase (Phase 3 — leave blank for now).
# The anon key is public by design; it is safe ONLY because Row-Level Security
# protects the data. Add RLS policies before storing any real data.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Perenual — NOT VITE_ prefixed on purpose.
# Used only by a local, one-off Node seed script (never queried from the
# browser in production). Keeping it unprefixed keeps it out of the bundle.
PERENUAL_KEY=your_perenual_key
